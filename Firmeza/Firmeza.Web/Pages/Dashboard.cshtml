@page
@model Firmeza.Web.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex items-center gap-4">
        <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center">
            <i class="bi bi-box-seam text-2xl text-blue-600"></i>
        </div>
        <div>
            <p class="text-slate-400 text-sm">Total Productos</p>
            <p class="text-slate-800 text-3xl font-bold">@Model.TotalProductos</p>
        </div>
    </div>
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex items-center gap-4">
        <div class="w-14 h-14 rounded-2xl bg-emerald-50 flex items-center justify-center">
            <i class="bi bi-people text-2xl text-emerald-600"></i>
        </div>
        <div>
            <p class="text-slate-400 text-sm">Total Clientes</p>
            <p class="text-slate-800 text-3xl font-bold">@Model.TotalClientes</p>
        </div>
    </div>
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex items-center gap-4">
        <div class="w-14 h-14 rounded-2xl bg-violet-50 flex items-center justify-center">
            <i class="bi bi-cart3 text-2xl text-violet-600"></i>
        </div>
        <div>
            <p class="text-slate-400 text-sm">Total Ventas</p>
            <p class="text-slate-800 text-3xl font-bold">@Model.TotalVentas</p>
        </div>
    </div>
</div>

<!-- Tables -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
            <h2 class="text-slate-700 font-semibold text-sm">Últimas Ventas</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
                        <th class="px-6 py-3 text-left">#</th>
                        <th class="px-6 py-3 text-left">Cliente</th>
                        <th class="px-6 py-3 text-right">Total</th>
                        <th class="px-6 py-3 text-left">Fecha</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var v in Model.UltimasVentas)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-3 text-slate-400 font-mono">#@v.Id</td>
                            <td class="px-6 py-3 text-slate-700 font-medium">@v.Cliente.Nombre</td>
                            <td class="px-6 py-3 text-right text-emerald-600 font-semibold">$@v.Total.ToString("N2")</td>
                            <td class="px-6 py-3 text-slate-400">@v.Fecha.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                    @if (!Model.UltimasVentas.Any())
                    {
                        <tr><td colspan="4" class="px-6 py-8 text-center text-slate-400">Sin ventas registradas</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
            <h2 class="text-slate-700 font-semibold text-sm">Productos con Bajo Stock</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
                        <th class="px-6 py-3 text-left">Producto</th>
                        <th class="px-6 py-3 text-left">Categoría</th>
                        <th class="px-6 py-3 text-center">Stock</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var p in Model.ProductosBajoStock)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-3 text-slate-700 font-medium">@p.Nombre</td>
                            <td class="px-6 py-3 text-slate-500">@p.Categoria</td>
                            <td class="px-6 py-3 text-center">
                                <span class="inline-block bg-red-100 text-red-600 text-xs font-semibold px-2.5 py-0.5 rounded-full">@p.Stock</span>
                            </td>
                        </tr>
                    }
                    @if (!Model.ProductosBajoStock.Any())
                    {
                        <tr><td colspan="3" class="px-6 py-8 text-center text-slate-400">Todo el stock está bien</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>