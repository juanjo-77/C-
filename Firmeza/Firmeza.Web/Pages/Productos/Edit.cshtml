@page "{id:int}"
@model Firmeza.Web.Pages.Productos.EditModel
@{
    ViewData["Title"] = "Editar Producto";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center">
                <i class="bi bi-pencil text-amber-600"></i>
            </div>
            <h2 class="text-slate-800 font-bold text-xl">Editar Producto</h2>
        </div>

        <form method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-600 rounded-xl px-4 py-3 text-sm"></div>
            <input asp-for="Producto.Id" type="hidden" />

            <div>
                <label asp-for="Producto.Nombre" class="block text-sm font-semibold text-slate-700 mb-1.5">Nombre</label>
                <input asp-for="Producto.Nombre" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" />
                <span asp-validation-for="Producto.Nombre" class="text-red-500 text-xs mt-1"></span>
            </div>

            <div>
                <label asp-for="Producto.Descripcion" class="block text-sm font-semibold text-slate-700 mb-1.5">Descripción</label>
                <textarea asp-for="Producto.Descripcion" rows="3" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50"></textarea>
            </div>

            <div>
                <label asp-for="Producto.Categoria" class="block text-sm font-semibold text-slate-700 mb-1.5">Categoría</label>
                <input asp-for="Producto.Categoria" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" />
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Producto.Precio" class="block text-sm font-semibold text-slate-700 mb-1.5">Precio ($)</label>
                    <input asp-for="Producto.Precio" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" />
                    <span asp-validation-for="Producto.Precio" class="text-red-500 text-xs mt-1"></span>
                </div>
                <div>
                    <label asp-for="Producto.Stock" class="block text-sm font-semibold text-slate-700 mb-1.5">Stock</label>
                    <input asp-for="Producto.Stock" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" />
                </div>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                    class="bg-amber-500 hover:bg-amber-600 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors flex items-center gap-2 text-sm">
                    <i class="bi bi-save"></i> Actualizar
                </button>
                <a asp-page="Index"
                   class="flex items-center gap-2 border border-slate-200 text-slate-600 hover:bg-slate-50 px-6 py-2.5 rounded-xl transition-colors text-sm">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>