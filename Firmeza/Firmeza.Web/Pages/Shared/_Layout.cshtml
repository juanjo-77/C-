<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Firmeza</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50:  '#eff6ff',
                            100: '#dbeafe',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        [x-cloak] { display: none; }
        .nav-link-active { background-color: #1e3a8a; border-left: 3px solid #3b82f6; color: white !important; }
    </style>
</head>
<body class="bg-slate-100 font-sans">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 flex flex-col fixed top-0 left-0 h-full z-50 shadow-2xl">
        <!-- Brand -->
        <div class="px-6 py-5 border-b border-slate-700">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-brand-600 flex items-center justify-content-center shadow">
                    <i class="bi bi-building-fill text-white text-lg flex items-center justify-center w-full h-full"></i>
                </div>
                <div>
                    <div class="text-white font-bold text-lg leading-tight">Firmeza</div>
                    <div class="text-slate-400 text-xs">Panel Administrativo</div>
                </div>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-1">
            <a href="/Dashboard"
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300 hover:bg-slate-800 hover:text-white transition-all text-sm font-medium group">
                <i class="bi bi-speedometer2 text-base w-5 text-center text-slate-400 group-hover:text-brand-400"></i>
                Dashboard
            </a>
            <a href="/Productos/Index"
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300 hover:bg-slate-800 hover:text-white transition-all text-sm font-medium group">
                <i class="bi bi-box-seam text-base w-5 text-center text-slate-400 group-hover:text-brand-400"></i>
                Productos
            </a>
            <a href="/Clientes/Index"
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300 hover:bg-slate-800 hover:text-white transition-all text-sm font-medium group">
                <i class="bi bi-people text-base w-5 text-center text-slate-400 group-hover:text-brand-400"></i>
                Clientes
            </a>
            <a href="/Ventas/Index"
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300 hover:bg-slate-800 hover:text-white transition-all text-sm font-medium group">
                <i class="bi bi-cart3 text-base w-5 text-center text-slate-400 group-hover:text-brand-400"></i>
                Ventas
            </a>
            <a href="/Importar/Index"
               class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300 hover:bg-slate-800 hover:text-white transition-all text-sm font-medium group">
                <i class="bi bi-file-earmark-excel text-base w-5 text-center text-slate-400 group-hover:text-brand-400"></i>
                Importar Excel
            </a>
        </nav>

        <!-- User + logout -->
        <div class="px-4 py-4 border-t border-slate-700">
            <div class="flex items-center gap-3 mb-3 px-2">
                <div class="w-8 h-8 rounded-full bg-brand-700 flex items-center justify-center">
                    <i class="bi bi-person-fill text-white text-sm"></i>
                </div>
                <div class="overflow-hidden">
                    <div class="text-white text-xs font-semibold truncate">@User.Identity?.Name</div>
                    <div class="text-slate-400 text-xs">Administrador</div>
                </div>
            </div>
            <form method="post" asp-page="/Account/Logout">
                @Html.AntiForgeryToken()
                <button type="submit"
                    class="w-full flex items-center justify-center gap-2 px-3 py-2 rounded-lg bg-slate-800 hover:bg-red-600 text-slate-300 hover:text-white text-sm transition-all">
                    <i class="bi bi-box-arrow-left"></i> Cerrar sesión
                </button>
            </form>
        </div>
    </aside>

    <!-- Main -->
    <div class="ml-64 flex-1 flex flex-col min-h-screen">

        <!-- Topbar -->
        <header class="bg-white border-b border-slate-200 px-8 py-4 flex items-center justify-between sticky top-0 z-40 shadow-sm">
            <div>
                <h1 class="text-slate-800 font-bold text-lg">@ViewData["Title"]</h1>
                <p class="text-slate-400 text-xs mt-0.5">Sistema de gestión — Firmeza</p>
            </div>
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center gap-1.5 bg-green-50 text-green-700 text-xs font-medium px-3 py-1 rounded-full">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> En línea
                </span>
            </div>
        </header>

        <!-- Content -->
        <main class="flex-1 p-8">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="bg-white border-t border-slate-200 text-center text-slate-400 text-xs py-4">
            © 2025 Firmeza — Materiales de Construcción
        </footer>
    </div>
</div>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>