@page
@model Firmeza.Web.Pages.Ventas.CreateModel
@{
    ViewData["Title"] = "Nueva Venta";
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Panel izquierdo -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <h2 class="text-slate-700 font-semibold mb-5 flex items-center gap-2">
                <i class="bi bi-person-check text-blue-500"></i> Seleccionar Cliente
            </h2>
            <select id="clienteId" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">-- Selecciona un cliente --</option>
                @foreach (var c in Model.Clientes)
                {
                    <option value="@c.Id">@c.Nombre — @c.Documento</option>
                }
            </select>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <h2 class="text-slate-700 font-semibold mb-5 flex items-center gap-2">
                <i class="bi bi-box-seam text-blue-500"></i> Agregar Productos
            </h2>
            <div class="flex gap-3 mb-5">
                <select id="productoSelect" class="flex-1 border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">-- Selecciona un producto --</option>
                    @foreach (var p in Model.Productos)
                    {
                        <option value="@p.Id" data-precio="@p.Precio" data-nombre="@p.Nombre" data-stock="@p.Stock">
                            @p.Nombre — $@p.Precio.ToString("N2") (Stock: @p.Stock)
                        </option>
                    }
                </select>
                <input type="number" id="cantidadInput" min="1" value="1"
                    class="w-24 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-center focus:outline-none focus:ring-2 focus:ring-blue-500" />
                <button type="button" onclick="agregarProducto()"
                    class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors flex items-center gap-2">
                    <i class="bi bi-plus-lg"></i> Agregar
                </button>
            </div>

            <div class="overflow-x-auto rounded-xl border border-slate-100">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
                            <th class="px-4 py-3 text-left">Producto</th>
                            <th class="px-4 py-3 text-right">Precio Unit.</th>
                            <th class="px-4 py-3 text-center">Cant.</th>
                            <th class="px-4 py-3 text-right">Subtotal</th>
                            <th class="px-4 py-3"></th>
                        </tr>
                    </thead>
                    <tbody id="detallesBody" class="divide-y divide-slate-50">
                        <tr id="filaVacia">
                            <td colspan="5" class="px-4 py-8 text-center text-slate-400">
                                <i class="bi bi-cart3 text-2xl block mb-2"></i>
                                Agrega productos a la venta
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Panel derecho -->
    <div class="space-y-4">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <h2 class="text-slate-700 font-semibold mb-5">Resumen</h2>
            <div class="space-y-3 text-sm">
                <div class="flex justify-between text-slate-500">
                    <span>Subtotal</span>
                    <span id="subtotalDisplay" class="font-medium text-slate-700">$0.00</span>
                </div>
                <div class="flex justify-between text-slate-500">
                    <span>IVA (19%)</span>
                    <span id="ivaDisplay" class="font-medium text-slate-700">$0.00</span>
                </div>
                <div class="border-t border-slate-100 pt-3 flex justify-between">
                    <span class="font-bold text-slate-800 text-base">Total</span>
                    <span id="totalDisplay" class="font-bold text-emerald-600 text-xl">$0.00</span>
                </div>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 border border-red-200 rounded-xl p-4">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>
            </div>
        }

        <form method="post" id="ventaForm">
            <input type="hidden" name="ClienteId" id="clienteIdHidden" />
            <input type="hidden" name="DetallesJson" id="detallesJson" />
            <button type="button" onclick="registrarVenta()"
                class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2 text-sm">
                <i class="bi bi-receipt"></i> Registrar Venta
            </button>
            <a asp-page="Index"
                class="mt-3 w-full flex items-center justify-center gap-2 border border-slate-200 text-slate-600 hover:bg-slate-50 font-medium py-3 rounded-xl transition-colors text-sm">
                Cancelar
            </a>
        </form>
    </div>
</div>

@section Scripts {
<script>
    let detalles = [];

    function agregarProducto() {
        const sel = document.getElementById('productoSelect');
        const cant = parseInt(document.getElementById('cantidadInput').value);
        if (!sel.value || cant < 1) { alert('Selecciona un producto y una cantidad válida'); return; }

        const opt = sel.options[sel.selectedIndex];
        const stock = parseInt(opt.dataset.stock);
        if (cant > stock) { alert(`Stock insuficiente. Disponible: ${stock}`); return; }

        const existente = detalles.find(d => d.productoId == parseInt(sel.value));
        if (existente) {
            existente.cantidad += cant;
        } else {
            detalles.push({
                productoId: parseInt(sel.value),
                nombre: opt.dataset.nombre,
                precio: parseFloat(opt.dataset.precio),
                cantidad: cant
            });
        }
        renderTabla();
    }

    function eliminarDetalle(idx) {
        detalles.splice(idx, 1);
        renderTabla();
    }

    function renderTabla() {
        const tbody = document.getElementById('detallesBody');
        if (detalles.length === 0) {
            tbody.innerHTML = '<tr id="filaVacia"><td colspan="5" class="px-4 py-8 text-center text-slate-400"><i class="bi bi-cart3 text-2xl block mb-2"></i>Agrega productos a la venta</td></tr>';
            actualizarTotales(0); return;
        }
        let html = '', subtotal = 0;
        detalles.forEach((d, i) => {
            const sub = d.precio * d.cantidad;
            subtotal += sub;
            html += `<tr class="hover:bg-slate-50">
                <td class="px-4 py-3 text-slate-700 font-medium">${d.nombre}</td>
                <td class="px-4 py-3 text-right text-slate-500">$${d.precio.toFixed(2)}</td>
                <td class="px-4 py-3 text-center text-slate-700">${d.cantidad}</td>
                <td class="px-4 py-3 text-right font-semibold text-slate-800">$${sub.toFixed(2)}</td>
                <td class="px-4 py-3 text-center">
                    <button type="button" onclick="eliminarDetalle(${i})"
                        class="text-red-400 hover:text-red-600 transition-colors">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </td>
            </tr>`;
        });
        tbody.innerHTML = html;
        actualizarTotales(subtotal);
    }

    function actualizarTotales(subtotal) {
        const iva = subtotal * 0.19;
        const total = subtotal + iva;
        document.getElementById('subtotalDisplay').textContent = '$' + subtotal.toFixed(2);
        document.getElementById('ivaDisplay').textContent = '$' + iva.toFixed(2);
        document.getElementById('totalDisplay').textContent = '$' + total.toFixed(2);
    }

    function registrarVenta() {
        const clienteId = document.getElementById('clienteId').value;
        if (!clienteId) { alert('Selecciona un cliente'); return; }
        if (detalles.length === 0) { alert('Agrega al menos un producto'); return; }
        document.getElementById('clienteIdHidden').value = clienteId;
        document.getElementById('detallesJson').value = JSON.stringify(
            detalles.map(d => ({ productoId: d.productoId, cantidad: d.cantidad }))
        );
        document.getElementById('ventaForm').submit();
    }
</script>
}