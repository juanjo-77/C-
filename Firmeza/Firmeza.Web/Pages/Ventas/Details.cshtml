@page "{id:int}"
@model Firmeza.Web.Pages.Ventas.DetailsModel
@{
    ViewData["Title"] = "Detalle de Venta";
}

<div class="max-w-3xl mx-auto space-y-6">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="px-8 py-5 border-b border-slate-100 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
                    <i class="bi bi-receipt text-blue-600"></i>
                </div>
                <div>
                    <h2 class="text-slate-800 font-bold text-lg">Venta #@Model.Venta?.Id</h2>
                    <p class="text-slate-400 text-xs">@Model.Venta?.Fecha.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>
            <a href="/recibos/recibo_@(Model.Venta?.Id).pdf" target="_blank"
               class="inline-flex items-center gap-2 bg-red-50 hover:bg-red-100 text-red-600 text-sm font-medium px-4 py-2 rounded-xl transition-colors border border-red-100">
                <i class="bi bi-file-pdf"></i> Descargar Recibo
            </a>
        </div>

        <div class="grid grid-cols-2 gap-0 divide-x divide-slate-100">
            <div class="px-8 py-5">
                <p class="text-slate-400 text-xs font-semibold uppercase tracking-wide mb-3">Cliente</p>
                <p class="text-slate-800 font-bold">@Model.Venta?.Cliente.Nombre</p>
                <p class="text-slate-500 text-sm mt-1">@Model.Venta?.Cliente.Documento</p>
                <p class="text-slate-500 text-sm">@Model.Venta?.Cliente.Correo</p>
                <p class="text-slate-500 text-sm">@Model.Venta?.Cliente.Telefono</p>
            </div>
            <div class="px-8 py-5">
                <p class="text-slate-400 text-xs font-semibold uppercase tracking-wide mb-3">Resumen</p>
                <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-400">IVA (19%)</span>
                        <span class="text-slate-700">$@Model.Venta?.IVA.ToString("N2")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-700 font-bold">Total</span>
                        <span class="text-emerald-600 font-bold text-lg">$@Model.Venta?.Total.ToString("N2")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="px-8 pb-6">
            <p class="text-slate-400 text-xs font-semibold uppercase tracking-wide mb-3">Productos</p>
            <div class="rounded-xl border border-slate-100 overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
                            <th class="px-5 py-3 text-left">Producto</th>
                            <th class="px-5 py-3 text-right">Precio Unit.</th>
                            <th class="px-5 py-3 text-center">Cant.</th>
                            <th class="px-5 py-3 text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @foreach (var d in Model.Venta?.Detalles ?? new())
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="px-5 py-3 font-medium text-slate-800">@d.Producto.Nombre</td>
                                <td class="px-5 py-3 text-right text-slate-500">$@d.PrecioUnitario.ToString("N2")</td>
                                <td class="px-5 py-3 text-center text-slate-600">@d.Cantidad</td>
                                <td class="px-5 py-3 text-right font-semibold text-slate-800">$@d.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="px-8 pb-6">
            <a asp-page="Index"
               class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-700 text-sm transition-colors">
                <i class="bi bi-arrow-left"></i> Volver a Ventas
            </a>
        </div>
    </div>
</div>