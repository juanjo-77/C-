@page
@model Firmeza.Web.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h2 class="text-slate-800 font-bold text-xl">Clientes</h2>
        <p class="text-slate-400 text-sm mt-0.5">@Model.Clientes.Count registros en total</p>
    </div>
    <div class="flex gap-2">
        <a href="/Clientes/ExportarExcel"
           class="inline-flex items-center gap-2 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 text-sm font-medium px-4 py-2 rounded-xl transition-colors border border-emerald-200">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </a>
        <a href="/Clientes/ExportarPdf"
           class="inline-flex items-center gap-2 bg-red-50 hover:bg-red-100 text-red-700 text-sm font-medium px-4 py-2 rounded-xl transition-colors border border-red-200">
            <i class="bi bi-file-earmark-pdf"></i> PDF
        </a>
        <a asp-page="Create"
           class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-xl transition-colors shadow-sm">
            <i class="bi bi-plus-lg"></i> Nuevo Cliente
        </a>
    </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-100">
        <form method="get" class="flex gap-3">
            <div class="relative flex-1 max-w-sm">
                <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
                <input type="text" name="buscar" value="@Model.Buscar"
                       class="w-full pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50"
                       placeholder="Buscar por nombre o documento..." />
            </div>
            <button type="submit"
                class="bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-medium px-4 py-2 rounded-xl transition-colors">
                Buscar
            </button>
            @if (!string.IsNullOrEmpty(Model.Buscar))
            {
                <a asp-page="Index"
                   class="bg-slate-100 hover:bg-slate-200 text-slate-500 text-sm px-4 py-2 rounded-xl transition-colors">
                    Limpiar
                </a>
            }
        </form>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide border-b border-slate-100">
                    <th class="px-6 py-3 text-left">#</th>
                    <th class="px-6 py-3 text-left">Nombre</th>
                    <th class="px-6 py-3 text-left">Documento</th>
                    <th class="px-6 py-3 text-left">Correo</th>
                    <th class="px-6 py-3 text-left">Teléfono</th>
                    <th class="px-6 py-3 text-left">Dirección</th>
                    <th class="px-6 py-3 text-center">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @foreach (var c in Model.Clientes)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 text-slate-400 font-mono text-xs">@c.Id</td>
                        <td class="px-6 py-4 font-semibold text-slate-800">@c.Nombre</td>
                        <td class="px-6 py-4 text-slate-600">@c.Documento</td>
                        <td class="px-6 py-4 text-slate-500">@c.Correo</td>
                        <td class="px-6 py-4 text-slate-500">@c.Telefono</td>
                        <td class="px-6 py-4 text-slate-500 max-w-xs truncate">@c.Direccion</td>
                        <td class="px-6 py-4 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <a asp-page="Edit" asp-route-id="@c.Id"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg bg-amber-50 hover:bg-amber-100 text-amber-600 transition-colors">
                                    <i class="bi bi-pencil text-xs"></i>
                                </a>
                                <a asp-page="Delete" asp-route-id="@c.Id"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-50 hover:bg-red-100 text-red-500 transition-colors">
                                    <i class="bi bi-trash text-xs"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Clientes.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-16 text-center text-slate-400">
                            <i class="bi bi-inbox text-4xl block mb-3 text-slate-300"></i>
                            No hay clientes registrados
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>