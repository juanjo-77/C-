@page
@model Firmeza.Web.Pages.Clientes.CreateModel
@{
    ViewData["Title"] = "Nuevo Cliente";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
                <i class="bi bi-person-plus text-blue-600"></i>
            </div>
            <h2 class="text-slate-800 font-bold text-xl">Nuevo Cliente</h2>
        </div>

        <form method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-600 rounded-xl px-4 py-3 text-sm"></div>

            <div>
                <label asp-for="Cliente.Nombre" class="block text-sm font-semibold text-slate-700 mb-1.5">Nombre</label>
                <input asp-for="Cliente.Nombre" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" placeholder="Nombre completo" />
                <span asp-validation-for="Cliente.Nombre" class="text-red-500 text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="Cliente.Documento" class="block text-sm font-semibold text-slate-700 mb-1.5">Documento</label>
                <input asp-for="Cliente.Documento" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" placeholder="Ej: 1234567890" />
                <span asp-validation-for="Cliente.Documento" class="text-red-500 text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="Cliente.Correo" class="block text-sm font-semibold text-slate-700 mb-1.5">Correo</label>
                <input asp-for="Cliente.Correo" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" placeholder="correo@ejemplo.com" />
                <span asp-validation-for="Cliente.Correo" class="text-red-500 text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="Cliente.Telefono" class="block text-sm font-semibold text-slate-700 mb-1.5">Teléfono</label>
                <input asp-for="Cliente.Telefono" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" placeholder="Ej: 3001234567" />
                <span asp-validation-for="Cliente.Telefono" class="text-red-500 text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="Cliente.Direccion" class="block text-sm font-semibold text-slate-700 mb-1.5">Dirección</label>
                <input asp-for="Cliente.Direccion" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50" placeholder="Dirección completa" />
                <span asp-validation-for="Cliente.Direccion" class="text-red-500 text-xs mt-1"></span>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors flex items-center gap-2 text-sm">
                    <i class="bi bi-save"></i> Guardar
                </button>
                <a asp-page="Index"
                   class="flex items-center gap-2 border border-slate-200 text-slate-600 hover:bg-slate-50 px-6 py-2.5 rounded-xl transition-colors text-sm">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>